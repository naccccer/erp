{
  "name": "erp",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm exec tsc --noEmit -p apps/api/tsconfig.json",
    "start:api": "pnpm exec ts-node --project apps/api/tsconfig.json apps/api/src/main.ts",
    "dev:api": "cross-env PORT=3001 pnpm start:api",
    "dev:web": "pnpm --dir apps/web exec next dev -p 3000",
    "ports:free": "powershell -NoProfile -ExecutionPolicy Bypass -File ai/scripts/free-ports.ps1",
    "dev:all": "pnpm run ports:free && concurrently --kill-others-on-fail -n API,WEB -c blue,green \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:structure-drift": "node ai/tests/structure-drift.test.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.16",
    "@prisma/client": "7.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "prisma": "^7.4.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
